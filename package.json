{
  "name": "tree-sitter-objcpp",
  "version": "0.1.0",
  "description": "Objective-C++ grammar for tree-sitter",
  "repository": "https://github.com/user/tree-sitter-objcpp",
  "license": "MIT",
  "author": "",
  "main": "bindings/node",
  "types": "bindings/node",
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-cpp": "0.23.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.9"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test"
  },
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ]
}
